  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "ignal *** Please Hold *** Receiving Incoming Signal *** Please Hold ***
    Receiv\n    \n    Hey! it's you from the future. If you're seeing this, that
    means something\n    went wrong with your time travel teleportation project.
    You'll have to find\n    the parts needed to fix your portal before you can do
    another time jump.\n    \n    According to my sensors, there should be 4 parts
    near you. Once you find\n    them, use your trigger to collect them, and automatically
    place them\n    back in their proper spot in the portal. If you get stuck, I've
    also added\n    a failsafe trigger at your feet, that will turn on the portal
    for you.\n\n\tBest of luck,\n\t\tSigned off by you from the future\t3 / 1 / 3118"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
